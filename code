                        loadProfileToHUD(MASTER_DATABANK[5].id); // Hot-load Goalkeeper Prithiv right from startup
                        initializeScrollReveal();
                        runHeroCounters();
                    }, 400);
                } else {
                    percentageWidth += 25;
                    progress.style.width = percentageWidth + "%";
                }
            }, 15);
        });

        // Dynamic Interface Render Logic matching Category Filters
        function renderRegistryInterface() {
            const tableBody = document.getElementById("ranking-table-body");
            tableBody.innerHTML = "";

            MASTER_DATABANK.forEach(player => {
                // Filter conditions matrix check
                if (currentFilter !== 'all' && player.category !== currentFilter) return;

                const tr = document.createElement("tr");
                tr.id = `row-${player.id}`;
                tr.className = "hover:bg-white/[0.02] cursor-pointer transition-all duration-200 group relative";
                tr.onclick = () => loadProfileToHUD(player.id);

                let statusBadgeHtml = `<span class="inline-block text-[9px] bg-zinc-900 text-[#aeaeaf] font-bold px-2.5 py-1 rounded-md tracking-wider">ACTIVE</span>`;
                if(player.id === "p2") { // Aryan MVP
                    statusBadgeHtml = `<span class="inline-block text-[9px] bg-gradient-to-r from-amber-500 to-amber-300 text-black font-black px-2.5 py-1 rounded-md tracking-wider shadow-md shadow-amber-500/10">MVP</span>`;
                } else if(player.category === "champ") {
                    statusBadgeHtml = `<span class="inline-block text-[9px] bg-gradient-to-r from-emerald-500 to-teal-500 text-black font-black px-2.5 py-1 rounded-md tracking-wider shadow-md shadow-emerald-500/10">WINNER</span>`;
                }

                tr.innerHTML = `
                    <td class="py-4.5 px-5 text-center font-black text-white text-base group-hover:text-emerald-400 transition-colors">${player.rank}</td>
                    <td class="py-4.5 px-4">
                        <span class="block font-bold text-white tracking-tight text-sm group-hover:underline">${player.name}</span>
                        <span class="text-[11px] text-[#86868b] uppercase tracking-wider font-semibold flex items-center gap-1">
                            <span class="w-1 h-1 rounded-full ${player.category === 'champ' ? 'bg-emerald-400' : 'bg-[#6e6e73]'}"></span>
                            ${player.pos} // System Core
                        </span>
                    </td>
                    <td class="py-4.5 px-4">
                        <span class="text-xs bg-white/5 border border-white/5 text-zinc-300 px-2.5 py-1 rounded-lg font-bold">${player.metric}</span>
                    </td>
                    <td class="py-4.5 px-4 text-center">${statusBadgeHtml}</td>
                `;
                tableBody.appendChild(tr);
            });
        }

        // Live Action HUD Loader Matrix System
        function loadProfileToHUD(id) {
            const player = MASTER_DATABANK.find(p => p.id === id);
            if(!player) return;

            // Cycle out and cycle in standard row highlights
            MASTER_DATABANK.forEach(p => {
                const elementRow = document.getElementById(`row-${p.id}`);
                if(elementRow) elementRow.classList.remove("active-row");
            });
            const targetRowSelected = document.getElementById(`row-${id}`);
            if(targetRowSelected) targetRowSelected.classList.add("active-row");

            // String parameter injections
            document.getElementById("hud-name").innerText = player.name;
            document.getElementById("hud-pos").innerText = player.pos;
            document.getElementById("hud-ovr").innerText = player.ovr;
            document.getElementById("hud-tier").innerText = player.tier;
            document.getElementById("hud-verdict").innerText = `"${player.verdict}"`;
            
            // Adjust glowing backdrop vector mesh dynamic parameters
            document.getElementById("hud-accent-glow").style.backgroundColor = player.glow;

            // Style custom OVR colors depending on elite metric profiles
            const ovrText = document.getElementById("hud-ovr");
            if (player.id === "p2") {
                ovrText.className = "text-4xl font-black heading-font tracking-tighter text-amber-400 drop-shadow-[0_0_15px_rgba(245,158,11,0.25)]";
            } else if (player.category === "champ") {
                ovrText.className = "text-4xl font-black heading-font tracking-tighter text-emerald-400 drop-shadow-[0_0_15px_rgba(16,185,129,0.25)]";
            } else {
                ovrText.className = "text-4xl font-black heading-font tracking-tighter text-white";
            }

            // Map Attributes frameworks bars dynamically
            const container = document.getElementById("hud-stats-container");
            container.innerHTML = "";

            Object.entries(player.stats).forEach(([label, value]) => {
                const scalePercentage = Math.min((value / 100) * 100, 100);
                
                const statBlock = document.createElement("div");
                statBlock.className = "space-y-1.5";
                
                // Color configuration variables depending on category status tags
                let barColor = "bg-white";
                if(player.id === "p2") barColor = "bg-amber-400";
                else if(player.category === "champ") barColor = "bg-emerald-400";

                statBlock.innerHTML = `
                    <div class="flex justify-between text-xs font-semibold">
                        <span class="text-[#86868b] uppercase tracking-wider text-[10px] font-bold">${label}</span>
                        <span class="text-white font-black">${value}</span>
                    </div>
                    <div class="h-[4px] w-full bg-white/5 rounded-full overflow-hidden">
                        <div class="h-full ${barColor} rounded-full transition-all duration-600 ease-out" style="width: 0%;" id="bar-${id}-${label.substring(0,3)}"></div>
                    </div>
                `;
                container.appendChild(statBlock);

                // Initialize expansion execution flow animation 
                setTimeout(() => {
                    const TargetBarElement = document.getElementById(`bar-${id}-${label.substring(0,3)}`);
                    if(TargetBarElement) TargetBarElement.style.width = scalePercentage + "%";
                }, 40);
            });
        }

        // Filter Sorting Execution Function
        function filterRegistry(filterType) {
            currentFilter = filterType;
            
            // Cycle tab class selectors
            document.querySelectorAll(".tab-btn").forEach(btn => {
                btn.classList.remove("active-tab", "text-white");
                btn.classList.add("text-[#86868b]");
            });
            
            const targetedTab = document.getElementById(`tab-${filterType}`);
            targetedTab.classList.add("active-tab", "text-white");
            targetedTab.classList.remove("text-[#86868b]");

            renderRegistryInterface();
            
            // Auto re-focus display container window to maintain structural layout balance
            const activeSubgroup = MASTER_DATABANK.filter(p => filterType === 'all' || p.category === filterType);
            if(activeSubgroup.length > 0) {
                loadProfileToHUD(activeSubgroup[0].id);
            }
        }

        // Hero Numerical Stat Incrementor Engine
        function runHeroCounters() {
            const targets = document.querySelectorAll("[data-target]");
            targets.forEach(counter => {
                const numericLimit = +counter.getAttribute("data-target");
                let internalVal = 0;
                const incrementSpeed = numericLimit / 25;
                
                const execCounter = () => {
                    if(internalVal < numericLimit) {
                        internalVal += Math.ceil(incrementSpeed);
                        if(internalVal > numericLimit) internalVal = numericLimit;
                        counter.innerText = internalVal;
                        setTimeout(execCounter, 30);
                    } else {
                        counter.innerText = numericLimit;
                    }
                };
                execCounter();
            });
        }

        // Scroll Animation Hooks Observer Frame
        function initializeScrollReveal() {
            const elements = document.querySelectorAll(".reveal");
            const observerInstance = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if(entry.isIntersecting) {
                        entry.target.classList.add("active");
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.05 });
            
            elements.forEach(el => observerInstance.observe(el));
        }
    </script>
</body>
