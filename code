        function updateHUD(p, el) {
            document.querySelectorAll('.glass-depth').forEach(g => g.classList.remove('active-row'));
            el.classList.add('active-row');
            
            document.getElementById('hud-name').innerText = p.name;
            document.getElementById('hud-pos').innerText = p.pos;
            document.getElementById('hud-ovr').innerText = p.ovr;
            
            statsEl.innerHTML = Object.entries(p.stats).map(([k, v]) => `
                <div class="group">
                    <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest mb-2 text-zinc-400"><span>${k}</span><span>${v}</span></div>
                    <div class="h-1.5 w-full bg-zinc-900 rounded-full overflow-hidden">
                        <div class="stat-bar h-full bg-emerald-500 rounded-full" style="width: 0%" data-val="${v}%"></div>
                    </div>
                </div>
            `).join('');
            
            setTimeout(() => {
                document.querySelectorAll('.stat-bar').forEach(b => b.style.width = b.dataset.val);
            }, 50);
        }
    </script>
