    <script>
        // Data Registry
        const MASTER_DATABANK = [
            { name: "Mohith", pos: "Striker", ovr: 85, stats: { PAC: 92, SHO: 88, DRI: 84, PHY: 84 } },
            { name: "Aryan", pos: "Winger", ovr: 84, stats: { PAS: 88, DRI: 88, PAC: 86, SHO: 82 } },
            { name: "Maanas", pos: "Goalkeeper", ovr: 77, stats: { REF: 83, DIV: 78, HAN: 77, POS: 76 } },
            { name: "Prithiv", pos: "Goalkeeper", ovr: 76, stats: { REF: 84, DIV: 78, HAN: 74, SPD: 72 } }
        ];

        const rosterEl = document.getElementById('roster');
        const statsEl = document.getElementById('stats-container');

        MASTER_DATABANK.forEach((p, idx) => {
            const div = document.createElement('div');
            div.className = "glass-depth p-6 rounded-2xl cursor-pointer hover:bg-emerald-900/10 transition-all";
            div.innerHTML = `<h4 class="font-bold text-lg">${p.name}</h4><p class="text-xs text-zinc-500 uppercase tracking-widest">${p.pos}</p>`;
            div.onclick = () => updateHUD(p, div);
            rosterEl.appendChild(div);
